{
  "name": "@elevenid/marty-blog",
  "version": "0.1.3",
  "description": "Marty Identity Protocol blog - posts, authors, and protocol guide",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElevenID/marty-blog.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./blog-page": {
      "import": "./dist/blog-page.js",
      "default": "./dist/blog-page.js"
    },
    "./blog-post-page": {
      "import": "./dist/blog-post-page.js",
      "default": "./dist/blog-post-page.js"
    },
    "./authors-page": {
      "import": "./dist/authors-page.js",
      "default": "./dist/authors-page.js"
    },
    "./author-page": {
      "import": "./dist/author-page.js",
      "default": "./dist/author-page.js"
    },
    "./foundations-page": {
      "import": "./dist/foundations-page.js",
      "default": "./dist/foundations-page.js"
    },
    "./prerender-data": {
      "import": "./dist/prerender-data.js",
      "default": "./dist/prerender-data.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "export:social-manifest": "node scripts/export-social-manifest.mjs",
    "export:social-image-manifest": "node scripts/export-social-image-manifest.mjs",
    "export:grammar-review": "node scripts/export-grammar-review-manifest.mjs",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=5",
    "@mui/material": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
