{
  "name": "@marty/blog",
  "version": "0.1.0",
  "description": "Marty Identity Protocol blog - posts, authors, and protocol guide",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./blog-page": {
      "import": "./src/components/BlogPage.jsx",
      "default": "./src/components/BlogPage.jsx"
    },
    "./blog-post-page": {
      "import": "./src/components/BlogPostPage.jsx",
      "default": "./src/components/BlogPostPage.jsx"
    },
    "./authors-page": {
      "import": "./src/components/AuthorsPage.jsx",
      "default": "./src/components/AuthorsPage.jsx"
    },
    "./author-page": {
      "import": "./src/components/AuthorPage.jsx",
      "default": "./src/components/AuthorPage.jsx"
    },
    "./foundations-page": {
      "import": "./src/components/FoundationsPage.jsx",
      "default": "./src/components/FoundationsPage.jsx"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "export:social-manifest": "node scripts/export-social-manifest.mjs",
    "export:social-image-manifest": "node scripts/export-social-image-manifest.mjs",
    "export:grammar-review": "node scripts/export-grammar-review-manifest.mjs",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=5",
    "@mui/material": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.8.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
